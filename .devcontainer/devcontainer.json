{
    "name": "TLPI-Development",
    "build": {
        "dockerfile": "Dockerfile"
    },
    // 1. Install Zsh natively via official Dev Container Features
    "features": {
        "ghcr.io/devcontainers/features/common-utils:1": {
            "installZsh": true,
            "configureZshAsDefaultShell": true
        }
    },
    "customizations": {
        "vscode": {
            // 2. Force VS Code's integrated terminal to use Zsh inside the container
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack"
            ]
        }
    },
    "remoteUser": "root"
}